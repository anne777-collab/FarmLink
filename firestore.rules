rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if ownsUserDoc(userId);
      allow create, update: if ownsUserDoc(userId);
    }

    match /workers/{workerId} {
      allow read: if signedIn();
      allow create, update: if ownsUserDoc(workerId);
    }

    match /farmers/{farmerId} {
      allow read: if signedIn();
      allow create, update: if ownsUserDoc(farmerId);
    }

    match /jobs/{jobId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.farmerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.farmerId == request.auth.uid ||
        resource.data.workerId == request.auth.uid
      );
      allow delete: if false;
    }

    match /jobApplications/{applicationId} {
      allow read: if signedIn() && (
        resource.data.workerId == request.auth.uid ||
        resource.data.farmerId == request.auth.uid
      );
      allow create: if signedIn() && request.resource.data.workerId == request.auth.uid;
      allow update: if signedIn() && resource.data.farmerId == request.auth.uid;
      allow delete: if false;
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if ownsUserDoc(resource.data.userId);
      allow create: if signedIn();
      allow update: if ownsUserDoc(resource.data.userId) && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if false;
    }
  }
}
